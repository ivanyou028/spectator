# Anthropic API Key for server-side proxy
# Set this in Vercel dashboard (Settings > Environment Variables)
# or in local .env file for development with Vercel CLI
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Vite-specific environment variables (for local development only)
# This is used by the Vite dev proxy (vite.config.ts)
VITE_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
