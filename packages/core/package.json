{
  "name": "@spectator/core",
  "version": "0.1.0",
  "description": "A composable TypeScript story engine for AI-powered narrative generation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ivanyou028/spectator.git",
    "directory": "packages/core"
  },
  "homepage": "https://ivanyou028.github.io/spectator/",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "ai": "^4.0.0"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=1.0.0",
    "@ai-sdk/openai": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": { "optional": true },
    "@ai-sdk/openai": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0"
  },
  "keywords": ["ai", "story", "narrative", "generation", "typescript", "engine", "streaming", "characters"],
  "license": "MIT"
}
